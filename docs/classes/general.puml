@startuml
' GOD's TRACKER (GuardiAnts) Application - Domain-Driven Design Class Diagram

//solo estan los bc fleet y "telemetry"
package "app" {

  package "fleet" {
    package "fleet.domain.model" {
      class Fleet <<Entity>> {
        +name: string
        +getName(): string
        +setName(name: string): void
      }
      class Vehicle <<Entity>> {
        +plate: string
        +fleet: Fleet
        +getPlate(): string
        +setPlate(plate: string): void
        +getFleet(): Fleet
        +setFleet(fleet: Fleet): void
      }
      Fleet "1" <|-- "*" Vehicle : contains
    }

    package "fleet.infrastructure" {
      class FleetsApiEndpoint {
        // Inherits methods from BaseApiEndpoint
      }
      class VehiclesApiEndpoint {
        // Inherits methods from BaseApiEndpoint
      }
      class FleetApi {
        -vehiclesEndpoint: VehiclesApiEndpoint
        -fleetsEndpoint: FleetsApiEndpoint
        +getVehicles(): Observable<Vehicle[]>
        +getVehicle(id: number): Observable<Vehicle>
        +createVehicle(vehicle: Vehicle): Observable<Vehicle>
      }
      class FleetAssembler <<Assembler>> {
        +toEntitiesFromResponse(response: FleetsResponse): Fleet[]
        +toEntityFromResource(resource: FleetResource): Fleet
        +toResourceFromEntity(entity: Fleet): FleetResource
      }
      class VehicleAssembler <<Assembler>> {
        +toEntitiesFromResponse(response: VehiclesResponse): Vehicle[]
        +toEntityFromResource(resource: VehicleResource): Vehicle
        +toResourceFromEntity(entity: Vehicle): VehicleResource
      }

      FleetAssembler --|> app.shared.infrastructure.BaseAssembler : implements
      VehicleAssembler --|> app.shared.infrastructure.BaseAssembler : implements
      FleetAssembler --> Fleet : converts to/from
      VehicleAssembler --> Vehicle : converts to/from
      FleetsApiEndpoint --> FleetAssembler : uses for conversion
      VehiclesApiEndpoint --> VehicleAssembler : uses for conversion
      FleetsApiEndpoint --|> app.shared.infrastructure.BaseApiEndpoint : extends
      VehiclesApiEndpoint --|> app.shared.infrastructure.BaseApiEndpoint : extends
      FleetApi --|> app.shared.infrastructure.BaseApi : extends
      FleetApi --> VehiclesApiEndpoint : delegates to
      FleetApi --> FleetsApiEndpoint : delegates to
    }

    package "fleet.application" {
      class FleetStore <<Store>> {
        +fleets: Fleet[]
        +vehicles: Vehicle[]
        +getFleets(): Fleet[]
        +getVehicles(): Vehicle[]
        +addFleet(fleet: Fleet): void
        +addVehicle(vehicle: Vehicle): void
        +updateVehicle(vehicle: Vehicle): void
        +removeVehicle(vehicleId: string): void
      }
      FleetStore --> Fleet : manages
      FleetStore --> Vehicle : manages
    }

    package "fleet.presentation.views" {
      class VehicleForm <<Component>> {
        +store: FleetStore
        +isEdit: boolean
        +vehicleId: number | null
        +submit(): void
      }
      class VehicleList <<Component>> {
        +store: FleetStore
        +displayedColumns: string[]
        +editVehicle(id: number): void
        +deleteVehicle(id: number): void
        +navigateToNew(): void
      }
      VehicleForm ..> FleetStore : uses
      VehicleList ..> FleetStore : uses
    }
  }

  package "telemetry" {
    package "telemetry.domain.model" {
      class TelemetryData <<Entity>> {
        +vehicleId: string
        +latitude: number
        +longitude: number
        +speed: number
        +timestamp: Date
        +getCoordinates(): string
      }
    }

    package "telemetry.infrastructure" {
      class TelemetryApiEndpoint {
        // Inherits methods from BaseApiEndpoint
        +streamRealTimeData(): Observable<TelemetryData>
      }
      class TelemetryApi {
        -telemetryEndpoint: TelemetryApiEndpoint
        +getLiveTracking(vehicleId: string): Observable<TelemetryData>
      }
      class TelemetryAssembler <<Assembler>> {
        +toEntityFromResource(resource: TelemetryResource): TelemetryData
      }

      TelemetryAssembler --|> app.shared.infrastructure.BaseAssembler : implements
      TelemetryAssembler --> TelemetryData : converts to/from
      TelemetryApiEndpoint --> TelemetryAssembler : uses
      TelemetryApiEndpoint --|> app.shared.infrastructure.BaseApiEndpoint : extends
      TelemetryApi --|> app.shared.infrastructure.BaseApi : extends
      TelemetryApi --> TelemetryApiEndpoint : delegates to
    }

    package "telemetry.application" {
      class TelemetryStore <<Store>> {
        +liveData: TelemetryData[]
        +updateLiveLocation(data: TelemetryData): void
      }
      TelemetryStore --> TelemetryData : manages
    }

    package "telemetry.presentation.views" {
      class LiveMapDashboard <<Component>> {
        +store: TelemetryStore
        +mapAdapter: any
        +renderMarkers(): void
      }
      LiveMapDashboard ..> TelemetryStore : uses
    }
  }

  package "shared" {
    package "shared.infrastructure" {
      abstract class BaseApiEndpoint {
        -http: HttpClient
        -endpointUrl: string
        -assembler: BaseAssembler
        +getAll(): Observable<BaseEntity[]>
        +getById(id: number): Observable<BaseEntity>
        +create(entity: BaseEntity): Observable<BaseEntity>
        +update(entity: BaseEntity, id: number): Observable<BaseEntity>
        +delete(id: number): Observable<void>
        #handleError(operation: string): (error: HttpErrorResponse) => Observable<never>
      }
      class BaseApi {
        +request(endpoint: string): any
      }
      interface BaseAssembler <<Assembler>> {
        +toEntitiesFromResponse(response: BaseResponse): BaseEntity[]
        +toEntityFromResource(resource: BaseResource): BaseEntity
        +toResourceFromEntity(entity: BaseEntity): BaseResource
      }
      class BaseEntity <<Entity>> {
        +id: string
        +getId(): string
        +setId(id: string): void
      }
      BaseApiEndpoint --> BaseApi : uses
      BaseApi --> BaseAssembler : uses
      BaseAssembler --> BaseEntity : converts to/from
    }

    package "shared.presentation.components" {
      class FooterContent <<Component>> {}
      class LanguageSwitcher <<Component>> {
        +currentLang: string
        +languages: string[]
        +useLanguage(language: string): void
      }
      class Layout <<Component>> {
        +options: {link: string, label: string}[]
      }
    }

    package "shared.presentation.views" {
      class About <<Component>> {}
      class Home <<Component>> {}
      class PageNotFound <<Component>> {
        +invalidPath: string
        +navigateToHome(): void
      }
    }

    Layout --> FooterContent : includes
    Layout --> LanguageSwitcher : includes
    Layout --> About : includes
    Layout --> Home : includes
    Layout --> PageNotFound : includes
  }

  class AppComponent <<Component>> {
    // Main application shell component
  }
  AppComponent --> app.shared.presentation.components.Layout : uses
}
@enduml
